rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All authenticated users can read/write business collections
    match /orders/{doc} {
      allow read, write: if request.auth != null;
    }
    match /transactions/{doc} {
      allow read, write: if request.auth != null;
    }
    match /suppliers/{doc} {
      allow read, write: if request.auth != null;
    }
    match /purchaseOrders/{doc} {
      allow read, write: if request.auth != null;
    }
    match /inventory/{doc} {
      allow read, write: if request.auth != null;
    }
    match /customers/{doc} {
      allow read, write: if request.auth != null;
    }
    match /sales/{doc} {
      allow read, write: if request.auth != null;
    }
    match /production/{doc} {
      allow read, write: if request.auth != null;
    }

    // Users collection:
    // - Any authenticated user can READ (needed for setup page + admin panel)
    // - Users can write their own doc (first login seeding + setup claim)
    // - Admins and owners can write any doc (role changes)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "owner"]
      );
    }
  }
}
